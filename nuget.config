<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Disable a stale per-user source ("JaliumLocal" in
    %APPDATA%\NuGet\NuGet.Config) that points at
    "...\Jalium.UI\src\managed\Jalium.UI.Build\bin\Release". The path only
    exists right after a Release build of Jalium.UI.Build, so any normal
    restore (Debug, fresh clone, CI) trips NU1301.
    The "JaliumLocal" defined in Jalium.UI.Gallery.Desktop\NuGet.Config (which
    points at ../../../Jalium.UI/src/packaging/nupkgs) overrides the global
    one for that project subtree, but the rest of the solution (Modules,
    Tests, Android, Core, and the cross-repo Jalium.UI projects) still
    inherits the broken global definition. Disabling it at the repo root
    makes restore stable for the whole .slnx without touching the per-user
    NuGet.Config.
  -->
  <disabledPackageSources>
    <add key="JaliumLocal" value="true" />
  </disabledPackageSources>
</configuration>
